rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    match /restaurants/{restaurantId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && 
                   firestore.get(/databases/(default)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid &&
                   request.resource.size < 2 * 1024 * 1024 && 
                   request.resource.contentType.matches('image/.*');
    }

    // Manter suporte para caminhos antigos durante a migração (Opcional)
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && (request.auth.token.email == "propagoumkd@gmail.com" || request.auth.token.email == "adm01@admin.com");
    }
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && (request.auth.token.email == "propagoumkd@gmail.com" || request.auth.token.email == "adm01@admin.com");
    }
  }
}
