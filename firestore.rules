rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções Auxiliares
    function isAuthenticated() {
      return request.auth != null;
    }

    // Função para verificar se o usuário é o dono do restaurante
    // Usamos exists() antes de get() para evitar erros se o doc não existir
    function isRestaurantOwner(restaurantId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/restaurants/$(restaurantId)) &&
             get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid;
    }

    // Regras para a coleção principal de Restaurantes
    match /restaurants/{restaurantId} {
      // Qualquer pessoa pode ler os dados básicos do restaurante (vitrine)
      allow read: if true;
      
      // Apenas usuários logados podem criar um restaurante
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      
      // Apenas o dono pode atualizar
      allow update: if isRestaurantOwner(restaurantId);
      
      // Subcoleções (Produtos, Categorias, Configurações, Cupons, Pedidos, Clientes)
      
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isRestaurantOwner(restaurantId);
      }

      match /products/{productId} {
        allow read: if true;
        allow write: if isRestaurantOwner(restaurantId);
      }

      match /settings/{settingId} {
        allow read: if true;
        allow write: if isRestaurantOwner(restaurantId);
      }

      match /coupons/{couponId} {
        // Permitimos leitura para qualquer um (necessário para o checkout validar o cupom)
        allow read: if true;
        // Apenas o dono pode gerenciar (criar, editar, deletar)
        allow write: if isRestaurantOwner(restaurantId);
      }

      match /orders/{orderId} {
        allow create: if true;
        allow read, update, delete: if isRestaurantOwner(restaurantId);
      }

      match /customers/{customerId} {
        // Clientes podem ser criados/lidos por qualquer um (para cashback no checkout)
        allow read, create, update: if true;
        // Apenas o dono pode deletar
        allow delete: if isRestaurantOwner(restaurantId);
      }
    }
    
    // Manter suporte para coleções legadas
    match /categories/{categoryId} { allow read, write: if isAuthenticated(); }
    match /products/{productId} { allow read, write: if isAuthenticated(); }
    match /settings/{settingId} { allow read, write: if isAuthenticated(); }
  }
}
